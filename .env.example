VOYAGER_WORKER_FORAGER_SERVER_PORT=3013
VOYAGER_WORKER_FORAGER_BOT_USERNAME=forager_bot
VOYAGER_SIMULATION_MODE=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Dedalus Machines
DEDALUS_API_KEY=
