# Photon / macOS iMessage bridge
PHOTON_API_KEY=
PHOTON_MODE=local
IMESSAGE_GROUP_ID=
PHOTON_SELF_IDENTIFIER=

# Supabase shared state
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# OpenClaw gateways
OPENCLAW_FAKE_MODE=false
FOREMAN_OPENCLAW_URL=http://localhost:8100
FOREMAN_OPENCLAW_TOKEN=
WORKER_MINER_OPENCLAW_URL=http://localhost:8111
WORKER_MINER_OPENCLAW_TOKEN=
WORKER_BUILDER_OPENCLAW_URL=http://localhost:8112
WORKER_BUILDER_OPENCLAW_TOKEN=
WORKER_FORAGER_OPENCLAW_URL=http://localhost:8113
WORKER_FORAGER_OPENCLAW_TOKEN=

# Worker runtime
WORKER_ID=worker-miner
HEARTBEAT_INTERVAL_MS=5000
FALLBACK_POLLING_MS=5000
STUCK_TIMEOUT_MS=600000

# Voyager execution
VOYAGER_PATH=
VOYAGER_SIMULATION_MODE=true

# Dedalus Machines
DEDALUS_API_KEY=
DEDALUS_CONTROL_MACHINE_ID=
DEDALUS_WORKER_MINER_MACHINE_ID=
DEDALUS_WORKER_BUILDER_MACHINE_ID=
DEDALUS_WORKER_FORAGER_MACHINE_ID=

# Local simulation
SIMULATION_DB_PATH=.simulation/openclaw-state.json
LOG_LEVEL=info
