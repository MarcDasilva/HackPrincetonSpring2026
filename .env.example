WORKER_FORAGER_OPENCLAW_TOKEN=

# Worker runtime
WORKER_ID=worker-miner
HEARTBEAT_INTERVAL_MS=5000
FALLBACK_POLLING_MS=5000
STUCK_TIMEOUT_MS=600000

# Voyager execution
VOYAGER_PATH=
VOYAGER_PYTHON=python3
VOYAGER_CKPT_DIR=
VOYAGER_MC_HOST=
